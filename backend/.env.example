# 🎬 AI Video Assistant — Environment Configuration Template
# Copy this file to '.env' and fill in your actual API keys.

# Google Gemini API Key (Required for Summarization, Extraction, RAG)
GOOGLE_API_KEY=your-google-gemini-api-key-here

# Sarvam AI API Key (Required for Hinglish transcription)
SARVAM_API_KEY=your-sarvam-api-key-here

# Whisper Configuration (Required for English transcription)
WHISPER_MODEL=small

# Sarvam STT Model Configuration
SARVAM_STT_MODEL=saaras:v2.5

# CORS configuration (Allowed frontend URLs separated by commas)
ALLOWED_ORIGINS=http://localhost:3000,https://your-production-frontend-domain.com

